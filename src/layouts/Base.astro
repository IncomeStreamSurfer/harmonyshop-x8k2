---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  structuredData?: object | object[];
  noindex?: boolean;
  tags?: string[];
}

const { title, description, ogImage, ogType, canonicalUrl, structuredData, noindex, tags } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={title}
    description={description}
    ogImage={ogImage}
    ogType={ogType}
    canonicalUrl={canonicalUrl}
    structuredData={structuredData}
    noindex={noindex}
    tags={tags}
  />
</head>
<body>
  <header style="position:sticky;top:0;z-index:50;background:rgba(15,15,15,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);">
    <nav class="container" style="display:flex;align-items:center;justify-content:space-between;height:64px;">
      <a href="/" style="font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--text);text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
        <svg width="28" height="28" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="100" height="100" rx="12" fill="#E8472A"/>
          <text x="50" y="68" font-size="60" text-anchor="middle" fill="white" font-family="serif">H</text>
        </svg>
        Harmony Threads
      </a>
      <div style="display:flex;align-items:center;gap:2rem;">
        <div style="display:flex;gap:1.5rem;">
          <a href="/shop" style="color:var(--text-muted);text-decoration:none;font-size:0.9rem;font-weight:500;">Shop</a>
          <a href="/about" style="color:var(--text-muted);text-decoration:none;font-size:0.9rem;font-weight:500;">About</a>
          <a href="/blog" style="color:var(--text-muted);text-decoration:none;font-size:0.9rem;font-weight:500;">Blog</a>
          <a href="/contact" style="color:var(--text-muted);text-decoration:none;font-size:0.9rem;font-weight:500;">Contact</a>
        </div>
        <a href="/shop" class="btn-primary" style="padding:0.5rem 1.25rem;font-size:0.875rem;">Shop Now</a>
      </div>
    </nav>
  </header>
  <main><slot /></main>
  <footer style="background:var(--bg-card);border-top:1px solid var(--border);margin-top:4rem;">
    <div class="container" style="padding-top:3rem;padding-bottom:2rem;">
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:3rem;margin-bottom:2rem;">
        <div>
          <div style="font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--text);margin-bottom:1rem;">Harmony Threads</div>
          <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.6;max-width:300px;">Wear the music you love. Premium graphic tees celebrating the icons who shaped rock history.</p>
        </div>
        <div>
          <h4 style="color:var(--text);font-size:0.85rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem;">Shop</h4>
          <nav style="display:flex;flex-direction:column;gap:0.6rem;">
            <a href="/shop" style="color:var(--text-muted);text-decoration:none;font-size:0.875rem;">All Products</a>
            <a href="/collections/graphic-tees" style="color:var(--text-muted);text-decoration:none;font-size:0.875rem;">Graphic Tees</a>
            <a href="/about" style="color:var(--text-muted);text-decoration:none;font-size:0.875rem;">About Us</a>
          </nav>
        </div>
        <div>
          <h4 style="color:var(--text);font-size:0.85rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem;">Support</h4>
          <nav style="display:flex;flex-direction:column;gap:0.6rem;">
            <a href="/contact" style="color:var(--text-muted);text-decoration:none;font-size:0.875rem;">Contact Us</a>
            <a href="/blog" style="color:var(--text-muted);text-decoration:none;font-size:0.875rem;">Blog</a>
          </nav>
        </div>
      </div>
      <div style="border-top:1px solid var(--border);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;">
        <p style="color:var(--text-muted);font-size:0.8rem;">© 2026 Harmony Threads. All rights reserved.</p>
        <p style="color:var(--text-muted);font-size:0.8rem;">Made with ❤️ for music fans</p>
      </div>
    </div>
  </footer>
  <script>
    if (!localStorage.getItem('ht_cart')) {
      localStorage.setItem('ht_cart', JSON.stringify([]));
    }
  </script>
</body>
</html>
