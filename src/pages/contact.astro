---
import Base from '../layouts/Base.astro';
export const prerender = false;
const sent = Astro.url.searchParams.get('sent') === '1';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmonyshop-x8k2.vercel.app';
const breadcrumb = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }, { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${siteUrl}/contact` }] };
---
<Base title="Contact Harmony Threads" description="Questions about your order, sizing, or a custom request? Contact Harmony Threads." structuredData={breadcrumb}>
  <section style="padding:4rem 0 2rem;background:linear-gradient(180deg,var(--bg-card) 0%,var(--bg) 100%);border-bottom:1px solid var(--border);">
    <div class="container"><nav style="font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem;"><a href="/" style="color:var(--text-muted);text-decoration:none;">Home</a><span style="margin:0 0.5rem;">→</span><span>Contact</span></nav>
    <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;">Get in touch</h1>
    <p style="color:var(--text-muted);">A real human will reply, usually within 24 hours.</p></div>
  </section>
  <section style="padding:4rem 0 6rem;">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;max-width:900px;">
      <div>
        {sent ? (
          <div style="background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.3);border-radius:10px;padding:2rem;text-align:center;">
            <div style="font-size:2rem;margin-bottom:1rem;">✓</div>
            <h2 style="color:#4ade80;margin-bottom:0.5rem;">Message sent!</h2>
            <p style="color:var(--text-muted);font-size:0.9rem;">We'll get back to you within 24 hours.</p>
          </div>
        ) : (
          <form action="/api/contact" method="POST" style="display:flex;flex-direction:column;gap:1.25rem;">
            <div><label for="name" style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Your name</label><input type="text" id="name" name="name" required placeholder="Your name" style="width:100%;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:0.65rem 0.875rem;color:var(--text);font-size:0.9rem;outline:none;" /></div>
            <div><label for="email" style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Email</label><input type="email" id="email" name="email" required placeholder="you@example.com" style="width:100%;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:0.65rem 0.875rem;color:var(--text);font-size:0.9rem;outline:none;" /></div>
            <div><label for="message" style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Message</label><textarea id="message" name="message" required rows="5" style="width:100%;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:0.65rem 0.875rem;color:var(--text);font-size:0.9rem;outline:none;resize:vertical;"></textarea></div>
            <button type="submit" class="btn-primary" style="align-self:flex-start;">Send Message</button>
          </form>
        )}
      </div>
      <div style="padding-top:0.5rem;">
        <h2 style="font-size:1.1rem;font-weight:600;margin-bottom:1.5rem;">Common questions</h2>
        {[{q:'Where do you ship?',a:'USA, Canada, UK, Australia, and most of Europe.'},{q:'How do I return?',a:'Email us within 30 days. Items must be unworn.'},{q:'Order not arrived?',a:'Contact us with your order number.'},{q:'Custom orders?',a:'Yes! Send us a message with requirements.'}].map(item => (
          <div style="padding-bottom:1.25rem;margin-bottom:1.25rem;border-bottom:1px solid var(--border);">
            <h3 style="font-size:0.9rem;font-weight:600;margin-bottom:0.4rem;">{item.q}</h3>
            <p style="color:var(--text-muted);font-size:0.85rem;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
