---
import Base from '../../layouts/Base.astro';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmonyshop-x8k2.vercel.app';
const breadcrumb = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }, { "@type": "ListItem", "position": 2, "name": "Graphic Tees", "item": `${siteUrl}/collections/graphic-tees` }] };
const collectionSchema = { "@context": "https://schema.org", "@type": "CollectionPage", "name": "Graphic Tees Collection — Harmony Threads", "url": `${siteUrl}/collections/graphic-tees` };
---
<Base title="Graphic Tees Collection | Music Apparel | Harmony Threads" description="Explore Harmony Threads' graphic tees collection. Premium music-inspired t-shirts celebrating rock legends. Sizes S–XL." structuredData={[breadcrumb, collectionSchema]} tags={['graphic tees','music tees','band t-shirts']}>
  <section style="padding:4rem 0 2rem;background:linear-gradient(180deg,var(--bg-card) 0%,var(--bg) 100%);border-bottom:1px solid var(--border);">
    <div class="container"><nav style="font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem;"><a href="/" style="color:var(--text-muted);text-decoration:none;">Home</a><span style="margin:0 0.5rem;">→</span><span>Graphic Tees</span></nav>
    <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;">Graphic Tees</h1>
    <p style="color:var(--text-muted);max-width:500px;">Wearable art for the music-obsessed. Screen-printed on 180gsm heavyweight cotton.</p></div>
  </section>
  <section style="padding:3rem 0 6rem;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2rem;">
        {[{color:'green',label:'Forest Green',filter:'none',badge:'Best Seller'},{color:'gray',label:'Slate Gray',filter:'grayscale(40%)',badge:null},{color:'red',label:'Crimson Red',filter:'hue-rotate(270deg) saturate(1.3)',badge:null}].map(v => (
          <a href={`/product/physical-product-the-band-t-shirt?color=${v.color}`} style="text-decoration:none;display:block;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-4px)'" onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'">
            <div style="position:relative;aspect-ratio:1;overflow:hidden;background:var(--bg-card2);">
              <img src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=600" alt={`The Band tee in ${v.label}`} style={`width:100%;height:100%;object-fit:cover;filter:${v.filter};`} loading="lazy" />
              {v.badge && <div style="position:absolute;top:0.75rem;left:0.75rem;background:var(--accent);color:white;font-size:0.7rem;font-weight:700;padding:0.25rem 0.6rem;border-radius:100px;">{v.badge}</div>}
            </div>
            <div style="padding:1.25rem;">
              <h2 style="font-size:0.95rem;font-weight:600;margin:0 0 0.5rem;">The Band Tee — {v.label}</h2>
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;"><span style="font-size:1.1rem;font-weight:700;">$19.99</span><span style="font-size:0.8rem;color:var(--text-muted);text-decoration:line-through;">$24.99</span><span style="font-size:0.7rem;color:#4ade80;font-weight:600;">20% off</span></div>
              <div style="color:var(--accent);font-size:0.875rem;font-weight:600;">Select Options →</div>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:3rem;text-align:center;"><p style="color:var(--text-muted);font-size:0.9rem;">See all products: <a href="/shop" style="color:var(--accent);text-decoration:none;">browse the full shop →</a></p></div>
    </div>
  </section>
</Base>
