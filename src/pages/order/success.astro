---
import Base from '../../layouts/Base.astro';
export const prerender = false;
---
<Base title="Order Confirmed! | Harmony Threads" description="Your Harmony Threads order is confirmed." noindex={true}>
  <section style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:4rem 0;">
    <div class="container" style="text-align:center;max-width:520px;">
      <div style="width:80px;height:80px;background:rgba(74,222,128,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2rem;">✓</div>
      <h1 style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;margin-bottom:0.75rem;color:#4ade80;">Order Confirmed!</h1>
      <p style="color:var(--text-muted);font-size:1rem;line-height:1.7;margin-bottom:0.5rem;">Thank you for shopping with Harmony Threads. Your order is confirmed and will ship within 2–3 business days.</p>
      <p style="color:var(--text-muted);font-size:0.875rem;margin-bottom:2rem;">A confirmation email is on its way to your inbox.</p>
      <div style="display:flex;gap:1rem;justify-content:center;">
        <a href="/shop" class="btn-primary">Shop More</a>
        <a href="/" class="btn-secondary">Back to Home</a>
      </div>
    </div>
  </section>
</Base>
