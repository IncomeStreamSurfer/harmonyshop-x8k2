---
import Base from '../layouts/Base.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmonyshop-x8k2.vercel.app';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Shop", "item": `${siteUrl}/shop` }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Harmony Threads Shop",
  "description": "Browse all music graphic tees from Harmony Threads.",
  "url": `${siteUrl}/shop`
};

const products = [
  { slug: 'physical-product-the-band-t-shirt', name: 'The Band Tee — Forest Green', color: 'green', colorLabel: 'Forest Green', price: 19.99, compareAt: 24.99, filter: 'none', badge: 'Best Seller' },
  { slug: 'physical-product-the-band-t-shirt', name: 'The Band Tee — Slate Gray', color: 'gray', colorLabel: 'Slate Gray', price: 19.99, compareAt: 24.99, filter: 'grayscale(40%)', badge: null },
  { slug: 'physical-product-the-band-t-shirt', name: 'The Band Tee — Crimson Red', color: 'red', colorLabel: 'Crimson Red', price: 19.99, compareAt: 24.99, filter: 'hue-rotate(270deg) saturate(1.3)', badge: null },
];
---

<Base
  title="Shop Music Graphic Tees | Harmony Threads"
  description="Browse our full collection of premium music graphic tees. The Band collection in Forest Green, Slate Gray, and Crimson Red. Sizes S–XL."
  structuredData={[breadcrumb, collectionSchema]}
  tags={["music tees", "graphic t-shirts", "The Band merch"]}
>
  <section style="padding:4rem 0 2rem;background:linear-gradient(180deg,var(--bg-card) 0%,var(--bg) 100%);border-bottom:1px solid var(--border);">
    <div class="container">
      <nav style="font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem;">
        <a href="/" style="color:var(--text-muted);text-decoration:none;">Home</a>
        <span style="margin:0 0.5rem;">→</span>
        <span>Shop</span>
      </nav>
      <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;">The Collection</h1>
      <p style="color:var(--text-muted);max-width:500px;">Premium music graphic tees for the serious fan. Wear your sound.</p>
    </div>
  </section>
  <section style="padding:3rem 0 5rem;">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid var(--border);">
        <div style="color:var(--text-muted);font-size:0.9rem;">{products.length} products</div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2rem;">
        {products.map(product => (
          <a href={`/product/${product.slug}?color=${product.color}`} style="text-decoration:none;display:block;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-4px)'" onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'">
            <div style="position:relative;aspect-ratio:1;overflow:hidden;background:var(--bg-card2);">
              <img src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=600" alt={`The Band tee in ${product.colorLabel}`} style={`width:100%;height:100%;object-fit:cover;filter:${product.filter};`} loading="lazy" />
              {product.badge && <div style="position:absolute;top:0.75rem;left:0.75rem;background:var(--accent);color:white;font-size:0.7rem;font-weight:700;padding:0.25rem 0.6rem;border-radius:100px;">{product.badge}</div>}
            </div>
            <div style="padding:1.25rem;">
              <div style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.35rem;">Harmony Threads</div>
              <h2 style="font-size:0.95rem;font-weight:600;margin:0 0 0.75rem;">{product.name}</h2>
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
                <span style="font-size:1.1rem;font-weight:700;">${product.price.toFixed(2)}</span>
                <span style="font-size:0.8rem;color:var(--text-muted);text-decoration:line-through;">${product.compareAt.toFixed(2)}</span>
                <span style="font-size:0.7rem;color:#4ade80;font-weight:600;">20% off</span>
              </div>
              <button style="width:100%;background:var(--accent);color:white;border:none;border-radius:6px;padding:0.65rem;font-weight:600;font-size:0.875rem;cursor:pointer;">Select Options</button>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:3rem;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:2rem;display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center;">
        <div><div style="font-size:1.5rem;margin-bottom:0.5rem;">🧵</div><div style="font-weight:600;margin-bottom:0.25rem;">180gsm Cotton</div><div style="color:var(--text-muted);font-size:0.8rem;">Heavyweight, structured feel</div></div>
        <div><div style="font-size:1.5rem;margin-bottom:0.5rem;">🖨️</div><div style="font-weight:600;margin-bottom:0.25rem;">Screen Printed</div><div style="color:var(--text-muted);font-size:0.8rem;">Water-based inks, wash-resistant</div></div>
        <div><div style="font-size:1.5rem;margin-bottom:0.5rem;">🚚</div><div style="font-weight:600;margin-bottom:0.25rem;">Ships in 2–3 Days</div><div style="color:var(--text-muted);font-size:0.8rem;">Free shipping over $50</div></div>
      </div>
    </div>
  </section>
</Base>
