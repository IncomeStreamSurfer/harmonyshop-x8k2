---
import Base from '../../layouts/Base.astro';
import { supabase } from '../../lib/supabase';
export const prerender = false;
const { slug } = Astro.params;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmonyshop-x8k2.vercel.app';
const { data: post, error } = await supabase.from('content').select('*').eq('slug', slug).not('published_at','is',null).single();
if (error || !post) { return Astro.redirect('/blog'); }
const articleSchema = { "@context": "https://schema.org", "@type": "BlogPosting", "headline": post.seo_title || post.title, "datePublished": post.published_at, "author": { "@type": "Organization", "name": "Harmony Threads" }, "publisher": { "@type": "Organization", "name": "Harmony Threads", "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } } };
const breadcrumb = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }, { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog` }, { "@type": "ListItem", "position": 3, "name": post.title, "item": `${siteUrl}/blog/${slug}` }] };
---
<Base title={post.seo_title || `${post.title} | Harmony Threads`} description={post.seo_description || post.excerpt || post.title} ogType="article" publishDate={post.published_at} structuredData={[articleSchema, breadcrumb]} tags={post.tags || []}>
  <article style="padding:4rem 0 6rem;">
    <div class="container" style="max-width:720px;">
      <nav style="font-size:0.8rem;color:var(--text-muted);margin-bottom:2rem;"><a href="/" style="color:var(--text-muted);text-decoration:none;">Home</a><span style="margin:0 0.5rem;">→</span><a href="/blog" style="color:var(--text-muted);text-decoration:none;">Blog</a><span style="margin:0 0.5rem;">→</span><span>{post.title}</span></nav>
      {post.published_at && <time style="font-size:0.8rem;color:var(--text-muted);" datetime={post.published_at}>{new Date(post.published_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</time>}
      <h1 style="font-family:'Playfair Display',serif;font-size:2.25rem;font-weight:700;margin:0.75rem 0 2rem;">{post.title}</h1>
      {post.cover_image_url && <div style="border-radius:12px;overflow:hidden;margin-bottom:2.5rem;aspect-ratio:16/9;"><img src={post.cover_image_url} alt={post.title} style="width:100%;height:100%;object-fit:cover;" /></div>}
      <div style="color:var(--text-muted);line-height:1.8;" set:html={post.body?.replace(/\n/g, '<br>') || ''} />
      <hr style="border:none;border-top:1px solid var(--border);margin:3rem 0;" />
      <div style="margin-top:3rem;padding:1.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;text-align:center;">
        <p style="color:var(--text-muted);margin-bottom:1rem;font-size:0.9rem;">Ready to wear the music? <a href="/shop" style="color:var(--accent);text-decoration:none;">Browse our collection →</a></p>
      </div>
    </div>
  </article>
</Base>
