---
import Base from '../../layouts/Base.astro';
import { supabase } from '../../lib/supabase';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmonyshop-x8k2.vercel.app';

const { data: posts } = await supabase
  .from('content')
  .select('slug, title, excerpt, published_at, cover_image_url, tags')
  .not('published_at', 'is', null)
  .order('published_at', { ascending: false });

const breadcrumb = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }, { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog` }] };
---
<Base title="Music Stories & Style | Harmony Threads Blog" description="Dive into the stories behind the music. The Harmony Threads blog covers rock history, artist spotlights, and style guides." structuredData={breadcrumb}>
  <section style="padding:4rem 0 2rem;background:linear-gradient(180deg,var(--bg-card) 0%,var(--bg) 100%);border-bottom:1px solid var(--border);">
    <div class="container"><nav style="font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem;"><a href="/" style="color:var(--text-muted);text-decoration:none;">Home</a><span style="margin:0 0.5rem;">→</span><span>Blog</span></nav>
    <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;">Music Stories</h1>
    <p style="color:var(--text-muted);">Deep dives into the artists and moments that shaped rock history.</p></div>
  </section>
  <section style="padding:4rem 0 6rem;">
    <div class="container">
      {posts && posts.length > 0 ? (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2rem;">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} style="text-decoration:none;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:block;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-3px)'" onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'">
              {post.cover_image_url && <div style="aspect-ratio:16/9;overflow:hidden;"><img src={post.cover_image_url} alt={post.title} style="width:100%;height:100%;object-fit:cover;" loading="lazy" /></div>}
              <div style="padding:1.5rem;">
                {post.published_at && <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.5rem;">{new Date(post.published_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</div>}
                <h2 style="font-size:1.05rem;font-weight:600;margin:0 0 0.6rem;">{post.title}</h2>
                {post.excerpt && <p style="color:var(--text-muted);font-size:0.875rem;line-height:1.6;">{post.excerpt}</p>}
                <div style="color:var(--accent);font-size:0.8rem;font-weight:600;margin-top:1rem;">Read more →</div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:5rem 0;">
          <div style="font-size:3rem;margin-bottom:1rem;">🎵</div>
          <h2 style="font-size:1.5rem;font-weight:600;margin-bottom:0.75rem;">Fresh articles coming soon</h2>
          <p style="color:var(--text-muted);margin-bottom:2rem;max-width:400px;margin-left:auto;margin-right:auto;">We're working on deep dives into rock history and artist spotlights. Sign up to hear first.</p>
          <form action="/api/subscribe" method="POST" style="display:flex;gap:0.75rem;justify-content:center;max-width:380px;margin:0 auto;">
            <input type="email" name="email" required placeholder="your@email.com" style="flex:1;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:0.6rem 0.875rem;color:var(--text);font-size:0.9rem;outline:none;" />
            <button type="submit" class="btn-primary" style="white-space:nowrap;padding:0.6rem 1.25rem;font-size:0.875rem;">Notify me</button>
          </form>
        </div>
      )}
    </div>
  </section>
</Base>
